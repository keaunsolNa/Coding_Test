/* Write your PL/SQL query statement below */
SELECT T1.employee_id
     , T1.department_id         
  FROM Employee T1
 WHERE T1.employee_id IN (SELECT employee_id
                            FROM Employee
                           GROUP BY employee_id
                           HAVING count(*) = 1 )
    OR T1.primary_flag = 'Y'                       
 ORDER BY T1.employee_id