/* Write your PL/SQL query statement below */
SELECT query_name
     , NVL(ROUND((SUM((rating / position)) / COUNT(query_name)), 2), 0) as quality
     , NVL(ROUND(((SELECT count(A.query_name)
                 FROM Queries A
                WHERE T1.query_name = A.query_name 
                  AND A.rating < 3
                GROUP BY A.query_name 
              ) / COUNT(query_name)) * 100, 2), 0)  as poor_query_percentage
  FROM Queries T1
 GROUP BY query_name 