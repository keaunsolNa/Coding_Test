/* Write your PL/SQL query statement below */
SELECT MANAGER.employee_id
     , MANAGER.name
     , COUNT(REPORTER.employee_id) AS reports_count
     , ROUND(AVG(REPORTER.age)) AS average_age
  FROM Employees MANAGER
  JOIN Employees REPORTER
    ON REPORTER.reports_to = MANAGER.employee_id
 GROUP BY MANAGER.employee_id, MANAGER.name
 ORDER BY MANAGER.employee_id
