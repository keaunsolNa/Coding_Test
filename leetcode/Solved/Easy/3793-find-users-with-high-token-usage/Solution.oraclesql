/* Write your PL/SQL query statement below */
SELECT T1.user_id
     , COUNT(T1.prompt) AS prompt_count
     , ROUND(AVG(T1.tokens), 2) AS avg_tokens
  FROM prompts T1
 GROUP BY user_id  
HAVING COUNT(T1.prompt) > 2
   AND MIN(T1.tokens) < MAX(T1.tokens)
ORDER BY ROUND(AVG(T1.tokens), 2) DESC, T1.user_id 